<Window x:Class="MessageHookTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF メッセージフック モニター" Height="860" Width="1000"
        MinWidth="700" MinHeight="620">
    <Window.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="50"/>
        </Style>
        <Style x:Key="WarnText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="OrangeRed"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- メインツールバー -->
        <ToolBar DockPanel.Dock="Top" Margin="2">
            <Button x:Name="BtnClearLog" Content="ログをクリア" Padding="8,3" Margin="2,0"
                    Click="BtnClearLog_Click"/>
            <Button x:Name="BtnExportLog" Content="ログをエクスポート" Padding="8,3" Margin="2,0"
                    Click="BtnExportLog_Click"/>
            <Separator/>
            <CheckBox x:Name="ChkAutoScroll" Content="自動スクロール" IsChecked="True"
                      VerticalAlignment="Center" Margin="4,0"/>
            <Separator/>
            <CheckBox x:Name="ChkWriteFile" Content="ファイルにも保存" IsChecked="True"
                      VerticalAlignment="Center" Margin="4,0"/>
            <Separator/>
            <TextBlock Text="頻度閾値 (回/秒):" VerticalAlignment="Center" Margin="4,0"/>
            <TextBox x:Name="TxtThreshold" Text="100" Width="50" Margin="2,0"
                     VerticalContentAlignment="Center"
                     TextChanged="TxtThreshold_TextChanged"/>
        </ToolBar>

        <!-- ログフィルタツールバー -->
        <ToolBar DockPanel.Dock="Top" Margin="2">
            <TextBlock Text="ログフィルタ:" VerticalAlignment="Center" Margin="4,0" FontWeight="Bold"/>
            <Separator/>
            <CheckBox x:Name="ChkFilterSystem"
                      Content="システム" IsChecked="True"
                      VerticalAlignment="Center" Margin="4,0"
                      Click="ChkFilter_Click"
                      ToolTip="監視開始/停止・エラーなどのシステムメッセージ（灰色）"/>
            <CheckBox x:Name="ChkFilterLocationChange"
                      Content="LocationChange" IsChecked="True"
                      VerticalAlignment="Center" Margin="4,0"
                      Click="ChkFilter_Click"
                      ToolTip="EVENT_OBJECT_LOCATIONCHANGE（黒／頻度超過時はオレンジ）"/>
            <CheckBox x:Name="ChkFilterWindowEvent"
                      Content="ウィンドウイベント" IsChecked="True"
                      VerticalAlignment="Center" Margin="4,0"
                      Click="ChkFilter_Click"
                      ToolTip="OBJECT_CREATE/DESTROY/SHOW/HIDE, SYSTEM_FOREGROUND, MOVESIZE など（青）"/>
            <CheckBox x:Name="ChkFilterDelayWarning"
                      Content="遅延警告" IsChecked="True"
                      VerticalAlignment="Center" Margin="4,0"
                      Click="ChkFilter_Click"
                      ToolTip="WinEvent の配送遅延が閾値を超えたときの警告（オレンジ太字）"/>
        </ToolBar>

        <!-- ステータスバー -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource HeaderText}" Text="GDI:"
                               ToolTip="GDI オブジェクト数（ブラシ・ペン・フォント・DC など）&#x0a;増え続ける場合は GDI リークの疑い"/>
                    <TextBlock x:Name="TxtGdi" Style="{StaticResource ValueText}" Text="0"
                               ToolTip="GDI オブジェクト数（ブラシ・ペン・フォント・DC など）&#x0a;増え続ける場合は GDI リークの疑い"/>
                    <TextBlock Style="{StaticResource HeaderText}" Text="  USER:" Margin="8,0,4,0"
                               ToolTip="User オブジェクト数（ウィンドウ・メニュー・アイコンなど）&#x0a;増え続ける場合は User オブジェクトリークの疑い"/>
                    <TextBlock x:Name="TxtUser" Style="{StaticResource ValueText}" Text="0"
                               ToolTip="User オブジェクト数（ウィンドウ・メニュー・アイコンなど）&#x0a;増え続ける場合は User オブジェクトリークの疑い"/>
                    <TextBlock Style="{StaticResource HeaderText}" Text="  ハンドル:" Margin="8,0,4,0"
                               ToolTip="カーネルハンドル数（ファイル・イベント・スレッドなど）&#x0a;増え続ける場合はハンドルリークの疑い"/>
                    <TextBlock x:Name="TxtHandles" Style="{StaticResource ValueText}" Text="0"
                               ToolTip="カーネルハンドル数（ファイル・イベント・スレッドなど）&#x0a;増え続ける場合はハンドルリークの疑い"/>
                    <TextBlock Style="{StaticResource HeaderText}" Text="  WS:" Margin="8,0,4,0"
                               ToolTip="Working Set（物理メモリ使用量）&#x0a;RAM 上に実際に載っているページの合計&#x0a;増え続ける場合はメモリリークの疑い"/>
                    <TextBlock x:Name="TxtWS" Style="{StaticResource ValueText}" Text="0 MB"
                               ToolTip="Working Set（物理メモリ使用量）&#x0a;RAM 上に実際に載っているページの合計&#x0a;増え続ける場合はメモリリークの疑い"/>
                    <TextBlock Style="{StaticResource HeaderText}" Text="  RDP:" Margin="8,0,4,0"
                               ToolTip="リモートデスクトップ（RDP）セッションかどうか&#x0a;YES = リモート接続中"/>
                    <TextBlock x:Name="TxtRdp" Style="{StaticResource ValueText}" Text="-"
                               ToolTip="リモートデスクトップ（RDP）セッションかどうか&#x0a;YES = リモート接続中"/>
                    <TextBlock Style="{StaticResource HeaderText}" Text="  DWM:" Margin="8,0,4,0"
                               ToolTip="Desktop Window Manager が有効かどうか&#x0a;OFF の場合はウィンドウ合成が無効（レガシーモード）"/>
                    <TextBlock x:Name="TxtDwm" Style="{StaticResource ValueText}" Text="-"
                               ToolTip="Desktop Window Manager が有効かどうか&#x0a;OFF の場合はウィンドウ合成が無効（レガシーモード）"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- メインコンテンツ -->
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="160"/>
            </Grid.RowDefinitions>

            <!-- 監視対象プロセス選択 -->
            <GroupBox Grid.Row="0" Header="監視対象プロセス" Margin="0,0,0,4">
                <Grid Margin="4,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="プロセス:" Style="{StaticResource HeaderText}"/>
                    <ComboBox x:Name="CmbProcess" Grid.Column="1"
                              Margin="0,0,4,0" DisplayMemberPath="DisplayName"
                              SelectionChanged="CmbProcess_SelectionChanged"/>
                    <TextBox x:Name="TxtProcessFilter" Grid.Column="2"
                             Margin="4,0" VerticalContentAlignment="Center"
                             TextChanged="TxtProcessFilter_TextChanged"
                             ToolTip="プロセス名・タイトル・PID でフィルタ"/>
                    <Button x:Name="BtnRefresh" Grid.Column="3" Content="一覧を更新"
                            Padding="8,3" Margin="4,0" Click="BtnRefresh_Click"/>
                    <Separator Grid.Column="4" Margin="4,0"/>
                    <Button x:Name="BtnStartStop" Grid.Column="5" Content="監視開始"
                            Padding="8,3" Margin="4,0" Width="80"
                            Click="BtnStartStop_Click"
                            Background="MediumSeaGreen" Foreground="White" FontWeight="Bold"/>
                </Grid>
            </GroupBox>

            <!-- GPU 情報・TDR パネル -->
            <GroupBox Grid.Row="1" Header="GPU / DWM / TDR" Margin="0,0,0,4">
                <Grid Margin="4,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource HeaderText}" Text="GPU:"/>
                        <TextBlock x:Name="TxtGpuInfo" Style="{StaticResource ValueText}"
                                   MinWidth="0" TextWrapping="NoWrap"/>
                        <Button x:Name="BtnCheckTdr" Content="TDR ログ確認" Padding="8,2"
                                Margin="16,0,0,0" Click="BtnCheckTdr_Click"/>
                    </StackPanel>
                    <ListBox x:Name="ListTdr" Grid.Row="1" Height="60" Margin="0,4,0,0"
                             FontFamily="Consolas" FontSize="10"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             Visibility="Collapsed"/>
                </Grid>
            </GroupBox>

            <!-- クォータ診断 -->
            <GroupBox Grid.Row="2" Header="クォータ診断" Margin="0,0,0,4">
                <Grid Margin="4,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock Style="{StaticResource HeaderText}" Text="Private:"/>
                        <TextBlock x:Name="TxtPrivate" Style="{StaticResource ValueText}" Text="-"
                                   ToolTip="監視対象プロセスの Private Bytes / Commit Size"/>
                        <TextBlock Style="{StaticResource HeaderText}" Text="  PagedPool:" Margin="16,0,4,0"/>
                        <TextBlock x:Name="TxtPagedPool" Style="{StaticResource ValueText}" Text="-"
                                   ToolTip="監視対象プロセスの paged pool 使用量"/>
                        <TextBlock Style="{StaticResource HeaderText}" Text="  NonPagedPool:" Margin="16,0,4,0"/>
                        <TextBlock x:Name="TxtNonPagedPool" Style="{StaticResource ValueText}" Text="-"
                                   ToolTip="監視対象プロセスの nonpaged pool 使用量"/>
                        <TextBlock Style="{StaticResource HeaderText}" Text="  Threads:" Margin="16,0,4,0"/>
                        <TextBlock x:Name="TxtThreads" Style="{StaticResource ValueText}" Text="-"
                                   ToolTip="監視対象プロセスのスレッド数"/>
                    </WrapPanel>

                    <WrapPanel Grid.Row="1" Margin="0,0,0,4">
                        <TextBlock Style="{StaticResource HeaderText}" Text="GUI Quota:"/>
                        <TextBlock x:Name="TxtGuiQuota" Style="{StaticResource ValueText}" Text="-"
                                   ToolTip="GDI/USER の current / peak / quota"/>
                        <TextBlock Style="{StaticResource HeaderText}" Text="  Commit:" Margin="16,0,4,0"/>
                        <TextBlock x:Name="TxtCommit" Style="{StaticResource ValueText}" Text="-"
                                   ToolTip="システム全体の commit 使用量 / 上限"/>
                        <TextBlock Style="{StaticResource HeaderText}" Text="  Avail RAM:" Margin="16,0,4,0"/>
                        <TextBlock x:Name="TxtAvailPhys" Style="{StaticResource ValueText}" Text="-"
                                   ToolTip="システム全体の空き物理メモリ"/>
                    </WrapPanel>

                    <WrapPanel Grid.Row="2">
                        <TextBlock Style="{StaticResource HeaderText}" Text="KernelPool:"/>
                        <TextBlock x:Name="TxtKernelPool" Style="{StaticResource ValueText}" Text="-"
                                   ToolTip="システム全体の kernel paged / nonpaged pool"/>
                        <TextBlock Style="{StaticResource HeaderText}" Text="  Session GUI:" Margin="16,0,4,0"/>
                        <TextBlock x:Name="TxtSessionGui" Style="{StaticResource ValueText}" Text="-"
                                   ToolTip="現在のセッション全体の GDI / USER オブジェクト数"/>
                        <TextBlock Style="{StaticResource HeaderText}" Text="  DesktopHeap:" Margin="16,0,4,0"/>
                        <TextBlock x:Name="TxtDesktopHeap" Style="{StaticResource ValueText}" Text="-"
                                   ToolTip="現在の desktop heap サイズと SharedSection 設定"/>
                        <TextBlock Style="{StaticResource HeaderText}" Text="  判定:" Margin="16,0,4,0"/>
                        <TextBlock x:Name="TxtQuotaDiagnosis" Style="{StaticResource ValueText}" Text="-"
                                   TextWrapping="Wrap"
                                   ToolTip="1816(ERROR_NOT_ENOUGH_QUOTA) の候補原因要約"/>
                    </WrapPanel>
                </Grid>
            </GroupBox>

            <!-- 統計パネル -->
            <GroupBox Grid.Row="3" Header="EVENT_OBJECT_LOCATIONCHANGE 統計" Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal" Margin="4,4">
                    <TextBlock Style="{StaticResource HeaderText}" Text="累計:"/>
                    <TextBlock x:Name="TxtTotalCount" Style="{StaticResource ValueText}" Text="0"/>
                    <TextBlock Style="{StaticResource HeaderText}" Text="  現在の頻度 (回/秒):" Margin="16,0,4,0"/>
                    <TextBlock x:Name="TxtFrequency" Style="{StaticResource ValueText}" Text="0"/>
                    <TextBlock Style="{StaticResource HeaderText}" Text="  最大頻度 (回/秒):" Margin="16,0,4,0"/>
                    <TextBlock x:Name="TxtMaxFrequency" Style="{StaticResource ValueText}" Text="0"/>
                    <TextBlock Style="{StaticResource HeaderText}" Text="  直近/最大遅延(ms):" Margin="16,0,4,0"
                               ToolTip="WinEvent が生成されてから監視側コールバックへ届くまでの遅延&#x0a;値が大きいほど監視対象側または配送経路の停滞の疑い"/>
                    <TextBlock x:Name="TxtEventLag" Style="{StaticResource ValueText}" Text="0 / 0"
                               ToolTip="直近遅延 / 最大遅延 (ms)"/>
                    <TextBlock x:Name="TxtWarning" Style="{StaticResource WarnText}"
                               Text="" Margin="16,0,0,0" Visibility="Collapsed"/>
                    <Button x:Name="BtnResetStats" Content="統計リセット" Padding="8,2"
                            Margin="16,0,0,0" Click="BtnResetStats_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- イベントログ -->
            <GroupBox Grid.Row="4" Header="イベントログ">
                <ListBox x:Name="ListLog" FontFamily="Consolas" FontSize="11"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
            </GroupBox>

            <GridSplitter Grid.Row="5" Height="4" HorizontalAlignment="Stretch" Margin="0,2"/>

            <!-- 例外ログ -->
            <GroupBox Grid.Row="6" Header="例外・診断ログ">
                <ListBox x:Name="ListExceptions" FontFamily="Consolas" FontSize="11"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
